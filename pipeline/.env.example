# RegShift pipeline LLM configuration.
# Default: local Ollama — nothing leaves your machine.
LLM_PROVIDER=ollama            # ollama | openai
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=qwen2.5-coder:7b
LLM_NUM_CTX=12288

# To use any OpenAI-compatible hosted endpoint instead:
# LLM_PROVIDER=openai
# LLM_BASE_URL=https://api.openai.com
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=sk-...
